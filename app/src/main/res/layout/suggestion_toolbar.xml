<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:background="@color/gboard_background_light">

    <ImageView
        android:id="@+id/toolbar_expand"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_keyboard_arrow_right"
        android:alpha="0.6" />

    <ImageView
        android:id="@+id/toolbar_stickers"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_stickers"
        android:alpha="0.6" />

    <ImageView
        android:id="@+id/toolbar_gif"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_gif"
        android:alpha="0.6" />

    <ImageView
        android:id="@+id/toolbar_clipboard"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_clipboard"
        android:alpha="0.6" />

    <ImageView
        android:id="@+id/toolbar_settings"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_settings"
        android:alpha="0.6" />

    <View
        android:layout_width="1dp"
        android:layout_height="24dp"
        android:background="#40808080"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp" />

    <ImageView
        android:id="@+id/toolbar_more"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_more_horiz"
        android:alpha="0.6" />

    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />

    <ImageView
        android:id="@+id/toolbar_mic"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="8dp"
        android:src="@drawable/ic_mic"
        android:alpha="0.6" />

</LinearLayout>
